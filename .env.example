# ============================================
# SERVER
# ============================================
NODE_ENV=development
ALLOW_DEMO_DELIVERY_ACTIONS=true
PORT=4500
HOST=0.0.0.0
API_VERSION=v1
APP_NAME=GroceryApp
FRONTEND_URL=http://localhost:4501
ADMIN_URL=http://localhost:4501
CORS_ORIGINS=http://localhost:4501,http://localhost:3001,http://localhost:3002,https://dash.bakaloo.shotlin.in

# ============================================
# JWT TOKENS
# ============================================
JWT_ACCESS_SECRET=your_super_secret_access_key_min_64_chars_long_here_change_me_now
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_long_here_change_me_now
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_SECRET=your_cookie_signing_secret_min_32_chars

# ============================================
# POSTGRESQL DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grocery_db
DB_USER=grocery_user
DB_PASSWORD=your_strong_database_password_here
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000
DB_CONNECT_RETRIES=20
DB_CONNECT_RETRY_DELAY=1000
DB_SSL=false

# ============================================
# REDIS CACHE
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_DEFAULT=600

# ============================================
# OTP CONFIGURATION
# ============================================
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_SECONDS=1800
OTP_LENGTH=6
# Development-only demo OTP bypass for one exact phone number
ALLOW_DEMO_OTP=false
DEMO_OTP_PHONE=9999999999
DEMO_OTP_CODE=123456
ALLOW_ALL_PINCODES=false

# ============================================
# RAZORPAY PAYMENT GATEWAY
# ============================================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
RAZORPAY_CURRENCY=INR

# ============================================
# SMS OTP (2Factor.in)
# ============================================
TWO_FACTOR_API_KEY=your_2factor_api_key_here
TWO_FACTOR_BASE_URL=https://2factor.in/API/V1

# ============================================
# FIREBASE (Push Notifications — FCM)
# Set FCM_ENABLED=true only when credentials are configured
# ============================================
FCM_ENABLED=false
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ============================================
# CLOUDINARY (Image CDN)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
CLOUDINARY_UPLOAD_PRESET=grocery_products
CLOUDINARY_FOLDER=grocery-app

# ============================================
# EMAIL (Resend)
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=GroceryApp

# ============================================
# GOOGLE MAPS (Delivery Tracking — optional)
# ============================================
# GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# GOOGLE OAUTH (Social Login)
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
OTP_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW=300000

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ============================================
# DELIVERY CONFIGURATION
# ============================================
DELIVERY_RADIUS_KM=10
EXPRESS_DELIVERY_MINUTES=30
PLATFORM_FEE=5
FREE_DELIVERY_ABOVE=299
COD_MAX_AMOUNT=2000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_PRETTY=true
ENABLE_SWAGGER=true

# ============================================
# BOOT-TIME GUARDS
# ============================================
# STRICT_PERMISSION_AUDIT — when true, fail boot (exit 1) if any protected
# dashboard route lacks a canonical Permission_String per R17 AC#9
# (multi-vendor design §4.5). Default false until Phase C wires
# `requiredPermission` onto every protected route.
STRICT_PERMISSION_AUDIT=false

# STRICT_SESSION_VERSION_CHECK — when true, the auth plugin rejects any
# JWT missing the `session_version` claim with 401 SESSION_INVALID per
# R20.8 (multi-vendor design §5.5). Default false so legacy in-flight
# tokens minted before migration 047 are accepted; the row-vs-claim
# comparison still runs whenever the claim IS present. Flip to true once
# all live tokens have rotated through the session_version-aware login,
# select-shop, and change-password flows.
STRICT_SESSION_VERSION_CHECK=false

# MULTI_VENDOR_PRODUCT_APPROVAL — opt-in HQ approval workflow for newly
# created Shop_Products (R23.10, R23.11, R23.22, R23.23 / design §3.2.3
# + §17.3). Default false preserves backward-compatible "born APPROVED"
# behaviour. When true: manual-create persists with approval_status=
# PENDING, HQ /api/v1/admin/shop-products/:id/{approve,reject} endpoints
# enable, and customer-facing product queries gain approval_status=
# APPROVED to the visibility filter. While OFF, the approve/reject
# endpoints reply 503 FEATURE_DISABLED.
MULTI_VENDOR_PRODUCT_APPROVAL=false

# ============================================
# BULLMQ (Background Jobs)
# ============================================
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=
BULL_CONCURRENCY=5

# ============================================
# MONITORING
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
SENTRY_DSN=https://xxx@sentry.io/xxx
