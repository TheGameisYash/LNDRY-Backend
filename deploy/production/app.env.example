NODE_ENV=production
APP_NAME=Bakaloo Backend
HOST=0.0.0.0
PORT=3000
API_VERSION=v1

FRONTEND_URL=https://bakaloo.shotlin.in
ADMIN_URL=https://bakaloodashboard.shotlin.in
CORS_ORIGINS=https://bakaloodashboard.shotlin.in,https://dashboard.shotlin.in

JWT_ACCESS_SECRET=replace_with_a_64_plus_character_secret
JWT_REFRESH_SECRET=replace_with_a_different_64_plus_character_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_SECRET=replace_with_a_32_plus_character_secret

DB_NAME=grocery_db
DB_USER=grocery_user
DB_PASSWORD=replace_with_a_strong_database_password
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000
DB_CONNECT_RETRIES=30
DB_CONNECT_RETRY_DELAY=1000
DB_SSL=false

REDIS_PASSWORD=replace_with_a_strong_redis_password
REDIS_DB=0
REDIS_TTL_DEFAULT=600

ALLOW_DEMO_OTP=false
DEMO_OTP_PHONE=9999999999
DEMO_OTP_CODE=123456
ALLOW_ALL_PINCODES=false
ALLOW_DEMO_DELIVERY_ACTIONS=false
SMS_PROVIDER=2factor
TWO_FACTOR_API_KEY=replace_with_2factor_api_key
TWO_FACTOR_TEMPLATE=GroceryAppOTP

RAZORPAY_KEY_ID=replace_with_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret
RAZORPAY_CURRENCY=INR

FCM_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_DATABASE_URL=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_FOLDER=grocery-app

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
OTP_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW=300000

MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

LOG_LEVEL=info
LOG_PRETTY=false
ENABLE_SWAGGER=false

DELIVERY_RADIUS_KM=10
EXPRESS_DELIVERY_MINUTES=30
PLATFORM_FEE=5
FREE_DELIVERY_ABOVE=499
DELIVERY_FEE=25

BULL_REDIS_PASSWORD=replace_with_a_strong_redis_password
BULL_CONCURRENCY=5
