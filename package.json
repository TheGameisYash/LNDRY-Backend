{
  "name": "bakaloo-backend",
  "version": "1.0.0",
  "description": "Laundry service booking and fulfilment platform — Fastify backend API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down",
    "setup:local": "npm run infra:up && npm run db:migrate && npm run db:seed",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:api": "node src/server.js",
    "start:worker": "node src/worker.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "node src/database/seeds/run.js",
    "seed:stores": "node scripts/seed-store-tabs.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@bull-board/fastify": "^5.20.0",
    "@fastify/compress": "^7.0.3",
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.4",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.0",
    "axios": "^1.7.3",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.70.0",
    "cloudinary": "^2.4.0",
    "csv-parse": "^6.1.0",
    "dayjs": "^1.11.12",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "firebase-admin": "^12.7.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "otplib": "^12.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "razorpay": "^2.9.2",
    "resend": "^3.4.0",
    "sharp": "^0.33.4",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "twilio": "^5.2.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "eslint": "^9.8.0",
    "fast-check": "^4.8.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
