COMPOSE_PROJECT_NAME=bakaloo
TZ=Asia/Kolkata

POSTGRES_DB=grocery_db
POSTGRES_USER=grocery_user
POSTGRES_PASSWORD=replace_with_a_strong_database_password
REDIS_PASSWORD=replace_with_a_strong_redis_password

POSTGRES_DATA_DIR=/srv/bakaloo/postgres
REDIS_DATA_DIR=/srv/bakaloo/redis
BACKUP_DIR=/srv/bakaloo/backups

AWS_REGION=ap-south-1
BACKUP_S3_BUCKET=replace_with_backup_bucket_name
BACKUP_S3_PREFIX=postgres
BACKUP_RETENTION_DAYS=14
BACKUP_SCHEDULE=0 */6 * * *
